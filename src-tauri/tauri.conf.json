{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notion",
  "version": "0.1.0",
  "identifier": "app.notionwrapper",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "Notion",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "url": "https://www.notion.so",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis"],
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Notion as a desktop app",
    "longDescription": "Notion packaged as a native desktop application via Tauri",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
