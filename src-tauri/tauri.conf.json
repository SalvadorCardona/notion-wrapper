{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebappWrapper",
  "version": "0.1.0",
  "identifier": "io.animalink.webappwrapper",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "WebappWrapper",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "url": "https://example.com",
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Webapp as desktop app",
    "longDescription": "A generic Tauri wrapper that turns webapps into native desktop apps",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
